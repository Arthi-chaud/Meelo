{
	"extends": [
		"expo/tsconfig.base"
	],
	"compilerOptions": {
		"strict": true,
		"paths": {
			"~/*": [
				"./*"
			],
			"@/models/*": [
				"../../../packages/models/src/*"
			],
			"@/utils/*": [
				"../../../packages/utils/src/*"
			],
			"@/api": [
				"../../../packages/api/src/index"
			],
			"@/api/*": [
				"../../../packages/api/src/*"
			],
			"@/state/*": [
				"../../../packages/state/src/*"
			],
			"@/components/*": [
				"../../../packages/components/src/*"
			]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"../../packages/utils/src/*.d.ts"
	]
}
