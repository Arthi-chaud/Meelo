{
	"extends": ["expo/tsconfig.base"],
	"compilerOptions": {
		"strict": true,
		"baseUrl": "./",
		"paths": {
			"iconsax-react": ["iconsax-react-nativejs"],
			"~/*": ["./*"],
			"@/models/*": ["../../packages/models/src/*"],
			"@/utils/*": ["../../packages/utils/src/*"],
			"@/api": ["../../packages/api/src/index"],
			"@/api/*": ["../../packages/api/src/*"],
			"@/state/*": ["../../packages/state/src/*"],
			"@/components/*": ["../../packages/components/src/*"],
			"@/primitives/*": ["../../packages/primitives/src/*"]
		}
	},
	"include": [
		"**/*.ts",
		"**/*.tsx",
		"../../packages/utils/src/*.d.ts",
		"nativewind.d.ts",
		".expo/types/**/*.ts",
		"expo-env.d.ts",
		"nativewind-env.d.ts"
	]
}
