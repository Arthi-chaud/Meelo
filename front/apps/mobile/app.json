{
	"expo": {
		"name": "Meelo",
		"slug": "meelo",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/icon-black.png",
		"scheme": "mobile",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true
		},
		"android": {
			"icon": "./assets/icon-black.png",
			"edgeToEdgeEnabled": true,
			"package": "com.arthichaud.meelo"
		},
		"plugins": [
			[
				"expo-font",
				{
					"fonts": [
						"./node_modules/@expo-google-fonts/rubik/Rubik_300Light.ttf",
						"./node_modules/@expo-google-fonts/rubik/Rubik_400Regular.ttf",
						"./node_modules/@expo-google-fonts/rubik/Rubik_500Medium.ttf",
						"./node_modules/@expo-google-fonts/rubik/Rubik_600SemiBold.ttf",
						"./node_modules/@expo-google-fonts/rubik/700Bold/Rubik_700Bold.ttf",
						"./node_modules/@expo-google-fonts/rubik/Rubik_800ExtraBold.ttf",
						"./node_modules/@expo-google-fonts/rubik/Rubik_900Black.ttf"
					]
				}
			],
			"expo-router",
			[
				"expo-splash-screen",
				{
					"image": "./assets/icon-black.png",
					"resizeMode": "contain",
					"imageWidth": 200,
					"backgroundColor": "#ffffff",
					"dark": {
						"image": "./assets/icon-white.png",
						"backgroundColor": "#242120"
					}
				}
			]
		],
		"experiments": {
			"typedRoutes": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "b8d8dcdb-a905-4674-9c62-db4256e0d94f"
			}
		}
	}
}
